        <mxCell id="y-pcIhphUF0d3Msuzr21-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;ul&gt;&lt;li&gt;obs = [step,...,num_steps-1]&lt;/li&gt;&lt;li&gt;dones = [step,...,num_steps-1]&lt;/li&gt;&lt;/ul&gt;" vertex="1">
