        <mxCell id="y-pcIhphUF0d3Msuzr21-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Agent Training&lt;/h1&gt;&lt;p&gt;for every episode, initialize: &lt;br&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;next_obs, _ = env.reset()&lt;/li&gt;&lt;li&gt;next_done = [0]&lt;/li&gt;&lt;li&gt;store both next_obs &amp;amp; next_done to device&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;for each step:&lt;/p&gt;" vertex="1">
