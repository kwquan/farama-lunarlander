        <mxCell id="y-pcIhphUF0d3Msuzr21-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Args &lt;/b&gt;Class&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: center;&quot;&gt;num_episodes = 2500&lt;/li&gt;&lt;li&gt;num_steps = 512&lt;/li&gt;&lt;li&gt;gamma = 0.99&lt;/li&gt;&lt;li&gt;gae_lambda = 0.95&lt;/li&gt;&lt;li&gt;batch_size = 512&lt;/li&gt;&lt;li&gt;minibatch_size = 32&lt;/li&gt;&lt;li&gt;clip_coef = 0.2&lt;/li&gt;&lt;li&gt;ent_coef = 0.02&lt;/li&gt;&lt;li&gt;vf_coef = 0.5&lt;/li&gt;&lt;li&gt;norm_adv = True&lt;/li&gt;&lt;li&gt;update_epochs = 4&lt;/li&gt;&lt;li&gt;max_grad_norm = 0.5&lt;/li&gt;&lt;li&gt;learning_rate = 2.5e-4&lt;/li&gt;&lt;li&gt;train_agent = True&lt;/li&gt;&lt;li&gt;render_episodes = 50&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="240" x="-670" y="235" as="geometry" />
        </mxCell>
        <mxCell id="y-pcIhphUF0d3Msuzr21-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;layer_init&lt;/b&gt;&amp;nbsp;Function&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;initializes layer using orthogonal weights[refer to below explanation for benefits] &amp;amp; constant bias 0&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="240" x="-670" y="530" as="geometry" />
        </mxCell>
        <mxCell id="y-pcIhphUF0d3Msuzr21-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;Agent&lt;/b&gt;&amp;nbsp;Class[&lt;b&gt;actor &lt;/b&gt;&amp;amp; &lt;b&gt;critic &lt;/b&gt;models]&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;actor&lt;/b&gt;: input layer: 8x64,&lt;br&gt;tanh activation,&amp;nbsp;&lt;br&gt;hidden layer: 64x64,&lt;br&gt;tanh activation,&lt;br&gt;output layer: 64x4&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;critic&lt;/b&gt;: input layer: 8x64,&lt;br&gt;tanh activation,&amp;nbsp;&lt;br&gt;hidden layer: 64x64,&lt;br&gt;tanh activation,&lt;br&gt;output layer: 64x1&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;get_value&lt;/b&gt; method which passes state input into critic &amp;amp; outputs estimated state value&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp;get_action_and_value &lt;/b&gt;method which passes state input into actor &amp;amp; outputs action probability distribution. Also outputs log_prob, entropy &amp;amp; critic output&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="340" width="240" x="-410" y="235" as="geometry" />
        </mxCell>
        <mxCell id="y-pcIhphUF0d3Msuzr21-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="start by: creating args" vertex="1">
